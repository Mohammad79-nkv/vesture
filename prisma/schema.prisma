// ──────────────────────────────────────────────────────────────────────
// Vesture — Prisma schema
// pgvector is enabled here from day 1 so Phase 3 needs no DB-extension migration.
// The `vector` column is unused until Phase 3.
// ──────────────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ─── Users ──────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  role      Role     @default(BUYER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sellerProfile SellerProfile?
  favorites     Favorite[]
  chatSessions  ChatSession[]
  adminActions  AdminAction[] @relation("AdminActor")
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

// ─── Sellers ────────────────────────────────────────────────────────────

model SellerProfile {
  id              String       @id @default(cuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeNameEn     String
  storeNameAr     String?
  slug            String       @unique
  bioEn           String?
  bioAr           String?
  logoUrl         String?
  coverUrl        String?
  instagramUrl    String?
  whatsappE164    String?
  countryCode     String       // ISO 3166-1 alpha-2 (AE, SA, EG, ...)
  defaultCurrency String       // ISO 4217 (AED, SAR, EGP, ...)
  status          SellerStatus @default(PENDING)
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  products Product[]

  @@index([status])
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

// ─── Products ───────────────────────────────────────────────────────────

model Product {
  id            String        @id @default(cuid())
  sellerId      String
  seller        SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  titleEn       String
  titleAr       String?
  slug          String        @unique
  descriptionEn String
  descriptionAr String?
  priceMinor    Int                                       // smallest currency unit
  currency      String                                    // ISO 4217

  category      Category
  gender        Gender
  season        Season?
  occasion      Occasion?
  style         Style?

  sizes         String[]
  colors        String[]                                  // normalized lowercase

  // Phase 3 fields — populated by AI tagging + embedding pipeline
  aiTags        String[]                                  @default([])
  aiConfidence  Float?
  embedding     Unsupported("vector(1024)")?
  embeddedAt    DateTime?

  status        ProductStatus @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  images       ProductImage[]
  favorites    Favorite[]
  chatMentions ChatMessageProduct[]

  @@index([sellerId, status])
  @@index([category, gender, status])
  @@index([priceMinor])
  @@index([status, publishedAt])
}

enum Category {
  TOPS
  BOTTOMS
  DRESSES
  OUTERWEAR
  SHOES
  BAGS
  ACCESSORIES
}

enum Gender {
  WOMEN
  MEN
  UNISEX
  KIDS
}

enum Season {
  SPRING
  SUMMER
  FALL
  WINTER
  ALL_SEASON
}

enum Occasion {
  CASUAL
  WORK
  FORMAL
  EVENING
  WEDDING
  VACATION
  SPORT
}

enum Style {
  MINIMAL
  STREETWEAR
  CLASSIC
  BOHO
  LUXURY
  VINTAGE
  EDGY
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
  REJECTED
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  publicId  String
  alt       String?
  position  Int     @default(0)

  @@index([productId, position])
}

// ─── Favorites ──────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ─── Chat (Phase 2) ─────────────────────────────────────────────────────

model ChatSession {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  anonymousCookie String?  @unique  // signed cookie value for pre-auth attach
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      ChatRole
  content   String
  toolCalls Json?
  createdAt DateTime @default(now())

  products ChatMessageProduct[]

  @@index([sessionId, createdAt])
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

// Many-to-many between ChatMessage and Product (products surfaced in a turn)
model ChatMessageProduct {
  messageId String
  productId String
  position  Int
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([messageId, productId])
  @@index([productId])
}

// ─── Admin audit log ────────────────────────────────────────────────────

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation("AdminActor", fields: [adminId], references: [id], onDelete: Cascade)
  targetType String   // "Seller" | "Product"
  targetId   String
  action     String   // "APPROVE" | "REJECT" | "SUSPEND" | "ARCHIVE"
  reason     String?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
}
